<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Le Guide Normand
			{% endblock %}
		</title>

		{# Bootstrap CSS #}
		<link
		href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
		{# Font Awesome #}
		<link
		href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
		{# Leaflet CSS #}
		<link
		href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" rel="stylesheet">
		{# Google Fonts #}
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

		<style>:root
		{
			--normand-red: #8B1A1A;
			--normand-red-dark: #6B1414;
			--normand-cream: #F5F0E8;
			--normand-gold: #C9A84C;
			--normand-green: #2D5A27;
			--normand-text: #2C2C2C;
		}

		body {
			font-family: 'Inter', sans-serif;
			background-color: #FAFAF8;
			color: var(--normand-text);
		}

		/* --- NAVBAR -- */
		.navbar-normand {
			background: linear-gradient(135deg, var(--normand-red) 0%, var(--normand-red-dark) 100%);
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
			padding: 0.5rem 0;
		}

		.navbar-normand .navbar-brand {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			text-decoration: none;
		}

		.navbar-brand-logo {
			height: 56px;
			width: auto;
			object-fit: contain;
		}

		.navbar-brand-text {
			font-family: 'Playfair Display', serif;
			font-size: 1.4rem;
			font-weight: 700;
			color: var(--normand-cream) !important;
			line-height: 1.1;
		}

		.navbar-brand-subtitle {
			font-size: 0.7rem;
			color: var(--normand-gold);
			letter-spacing: 0.1rem;
			text-transform: uppercase;
			font-family: 'Inter', sans-serif;
			font-weight: 500;
		}

		.navbar-normand .nav-link {
			color: rgba(255, 255, 255, 0.9) !important;
			font-weight: 500;
			font-size: 0.9rem;
			paddding: 0.5rem 0.9rem !important;
			border-radius: all 0.2s;
		}

		.navbar-normand .nav-link:hover,
		.navbar-normand .nav-link.active {
			color: #fff !important;
			backround: rgba(255, 255, 255, 0.15);
		}

		.navbar-normand .nav-link i {
			margin-right: 0.3rem;
		}

		.btn-navbar {
			background: var(--normand-gold);
			color: var(--normand-red-dark) !important;
			font-weight: 600;
			border-radius: 20px;
			padding: 0.4rem 1.1rem !important;
		}

		.btn-navbar:hover {
			background: #e0bb5a;
		}

		.navbar-toggler {
			border-color: rgba(255, 255, 255, 0.3);
		}

		.navbar-toggler-icon {
			filter: invert(1);
		}

		/* --- HERO --- */
		.hero-section {
			background: linear-gradient(135deg, var(--normand-red) 0%, #A52A2A 50%, var(--normand-green) 100%);
			color: white;
			padding: 4rem 0;
			position: relative;
			overflow: hidden;
		}

		.hero-section::before {
			content: '';
			position: absolute;
			inset: 0;
			background: url("data:image/svg+xml, %3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
			pointer-events: none;
		}


		/* --- CARDS --- */
		.card-normand {
			border: none;
			border-radius: 12px;
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
			transition: transform 0.2s, box-shadow 0.2s;
			overflow: hidden;
		}

		.card-normand:hover {
			transform: translateY(-4px);
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
		}

		.card-normand .card-img-top {
			height: 200px;
			object-fit: cover;
		}

		.card-normand .card-body {
			padding: 1.25rem;
		}

		/* --- BADGES CATEGORIES --- */
		.badge-categorie {
			background: var(--normand-red);
			color: white;
			font-size: 0.75rem;
			border-radius: 20px;
			font-weight: 500;
		}

		/* --- BOUTONS --- */
		.btn-normand {
			background: var(--normand-red);
			color: white;
			border: none;
			border-radius: 8px;
			font-weight: 500;
			transition: background 0.2s;
		}

		.btn-normand:hover {
			background: var(--normand-red-dark);
			color: white;
		}

		.btn-normand-outline {
			border: 2px solid var(--normand-red);
			color: var(--normand-red);
			background: transparent;
			border-radius: 8px;
			font-weight: 500;
			transition: all 0.2s;
		}

		.btn-normand-outline:hover {
			background: var(--normand-red);
			color: white;
		}

		/* --- ETOILES --- */
		.stars {
			color: var(--normand-gold);
		}

		/* --- SECTION TITLES --- */
		.section-title {
			font-family: 'Playfair Display', serif;
			color: var(--normand-red);
			font-weight: 700;
		}

		.section-divider {
			width: 60px;
			height: 3px;
			background: var(--normand-gold);
			margin: 0.5rem 0 1.5rem;
		}

		/* --- FOOTER --- */
		.footer-normand {
			background: var(--normand-red-dark);
			color: rgba(255, 255, 255, 0.85);
			paddding: 3rem 0 1.5rem;
			margin-top: 4rem;
		}

		.footer-normand h5 {
			font-family: 'Playfair Display', serif;
			color: var(--normand-gold);
			margin-bottom: 1rem;
		}

		.footer-normand a {
			color: rgba(255, 255, 255, 0.7);
			text-decoration: none;
			transition: color 0.2s;
		}

		.footer-normand a:hover {
			color: var(--normand-gold);
		}

		.footer-bottom {
			border-top: 1px solid rgba(255, 255, 255, 0.1);
			margin-top: 2rem;
			padding-top: 1rem;
			font-size: 1.2rem;
			color: rgba(255, 255, 255, 0.5);
		}

		/* --- ALERTES FLASH --- */
		.flash-messages {
			position: fixed;
			top: 80px;
			right: 1rem;
			z-index: 1050;
			min-width: 300px;
		}

		/* --- MAP --- */
		#map {
			height: 400px;
			border-radius: 12px;
			box-shodow: 0 2px 12px rgba(0, 0, 0, 0.1);
		}
	</style>

	{% block stylesheets %}{% endblock %}
</head>
<body>

	{# --- NAVBAR --- #}
	<nav class="navbar navbar-expand-lg navbar-normand sticky-top">
		<div class="container">
			<a clas="navbar-brand" href="{{ path('app_home') }}">
				<img src="{{ asset('images/logo.png') }}" alt="Le Guide Normand" class="navbar-brand-logo">
				<div>
					<div class="navbar-brand-text">Le Guide Normand</div>
					<div class="navbar-brand-subtitle">Découvrez la Normandie</div>
				</div>
			</a>

			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
				<span class="navbar-toggler-icon"></span>
			</button>

			<div class="collapse navbar-collapse" id="navbarMain">
				<ul class="navbar-nav me-auto ms-3 gap-1">
					<li class="nav-item">
						<a class="nav-link {{ app.request.get('_route') == 'app_lieu_index' ? 'active' : '' }}" href="{{ path('app_lieu_index') }}">
							<i class="fa-solid fa-map-location-dot"></i>
							Bons Plans
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link {{ app.request.get('_route') == 'app_terrain_index' ? 'active' : '' }}" href="{{ path('app_terrain_index') }}">
							<i class="fa-solid fa-tent"></i>
							Terrains
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="#">
							<i class="fa-solid fa-map"></i>
							Carte
						</a>
					</li>
				</ul>

				<ul class="navbar-nav gap-2 align-items-center">
					{% if app.user %}
						<li class="nav-item dropdown">
							<a class="nav-link drpdown-toggle" href="#" data-bs-toggle="dropdown">
								<i class="fa-solid fa-circle-user"></i>
								{{ app.user.prenom ?? app.user.email }}
							</a>
							<ul class="dropdown-menu dropdown-menu-end">
								<li>
									<a class="dropdown-item" href="#">
										<i class="fa-solid fa-user me-2"></i>Mon profil</a>
								</li>
								<li>
									<a class="dropdown-item" href="#">
										<i class="fa-solid fa-map-pin me-2"></i>Mes lieux</a>
								</li>
								<li>
									<a class="dropdown-item" href="#">
										<i class="fa-solid fa-tent me-2"></i>Mes terrains</a>
								</li>
								<li><hr class="dropdown-divider"></li>
								<li>
									<a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
										<i class="fa-solid fa-right-from-bracket me-2"></i>Déconnexion
									</a>
								</li>
							</ul>
						</li>
						<li class="nav-item">
							<a class="nav-link btn-navbar" href="#">
								<i class="fa-solod fa-plus"></i>
								Publier
							</a>
						{% else %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_login') }}">
									<i class="fa-solid fa-right-to-bracket"></i>
									Connexion
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link btn-navbar" href="{{ path('app_register') }}">
									<i class="fa-solid fa-user-plus"></i>
									S'inscrire
								</a>
							</li>
						{% endif %}
					</ul>
				</div>
			</div>
		</nav>

		{# --- Flash MESSAGES --- #}
		<div class="flash-message">
			{% for type, msgs in app.flashes %}
				{% for message in msgs %}
					<div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow" role="alert">
						{{ message }}
						<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
					</div>
				{% endfor %}
			{% endfor %}
		</div>

		{# --- CONTENU PRINCIPAL #}
		<main>
			{% block body %}{% endblock %}
		</main>

		{# --- FOOTER --- #}
		<footer class="footer-normand">
			<div class="container">
				<div class="row g-4">
					<div class="col-lg-4">
						<div class="d-flex align-items-center gap-3 mb-3">
							<img src="{{ asset('images/logo.png') }}" alt="Logo" height="50">
							<div>
								<h5 class="mb-0">Le Guide Normand</h5>
								<small class="text-white-50">Découvrez la Normandie</small>
							</div>
						</div>
						<p class="small">La communauté des amoureux de la Normandie. Partagez vos bons plans, randonnées, restaurants et lieux secrets.</p>
					</div>
					<div class="col-lg-2 col-6">
						<h5>Explorer</h5>
						<ul class="list-unstyled small">
							<li>
								<a href="{{ path('app_lieu_index') }}">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Bons Plans</a>
							</li>
							<li>
								<a href="{{ path('app_terrain_index') }}">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Terrains</a>
							</li>
							<li>
								<a href="{{ path('app_evenement_index') }}">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Événements</a>
							</li>
							<li>
								<a href="#">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Carte</a>
							</li>
						</ul>
					</div>
					<div class="col-lg-2 col-6">
						<h5>Communauté</h5>
						<ul class="list-unstyled small">
							<li>
								<a href="#">
									<i class="fa-solid fa-chevron-right me-1 small"></i>S'inscrire</a>
							</li>
							<li>
								<a href="#">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Publier un lieu</a>
							</li>
							<li>
								<a href="#">
									<i class="fa-solid fa-chevron-right me-1 small"></i>Proposer un terrain</a>
							</li>
						</ul>
					</div>
					<div class="col-lg-4">
						<h5>À propos</h5>
						<p class="small">Projet réalisé dans le cadre du titre professionnel DWWM — CEPPIC Isneauville 2025-2026.</p>
						<div class="d-flex gap-3 mt-2">
							<a href="#">
								<i class="fab fa-facebook fa-lg"></i>
							</a>
							<a href="#">
								<i class="fab fa-instagram fa-lg"></i>
							</a>
						</div>
					</div>
				</div>
				<div class="footer-bottom text-center">
					Copyright
					{{ "now"|date("Y") }}
					Le Guide Normand — Projet DWWM CEPPIC
				</div>
			</div>
		</footer>

		{# ── SCRIPTS ── #}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

		{% block javascripts %}{% endblock %}
	</body>
</body></html>
